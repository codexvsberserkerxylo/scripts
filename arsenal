local function getTarget()
    local mousePos = UIS:GetMouseLocation()
    local fov      = flags["fov_radius"]   or 150
    local maxDist  = flags["aim_max_dist"] or 500
    local root     = getRoot()
    local best, bestScore = nil, math.huge

    for _, pl in pairs(Players:GetPlayers()) do
        if pl==lp then continue end
        if flags["aim_team_check"] and pl.Team==lp.Team then continue end
        local c    = pl.Character
        local h    = c and c:FindFirstChildOfClass("Humanoid")
        local part = c and c:FindFirstChild(flags["aim_part"] or "Head")
        local hrp  = c and c:FindFirstChild("HumanoidRootPart")
        if not (c and h and part and hrp and h.Health>0) then continue end
        if root and (hrp.Position-root.Position).Magnitude>maxDist then continue end
        local sp,onScreen = cam:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local screenDist = (Vector2.new(sp.X,sp.Y)-mousePos).Magnitude
        if screenDist>fov then continue end
        local priority = flags["aim_priority"] or "Nearest Mouse"
        local score
        if     priority=="Nearest Mouse"    then score=screenDist
        elseif priority=="Nearest Distance" then score=root and (hrp.Position-root.Position).Magnitude or screenDist
        elseif priority=="Lowest HP"        then score=h.Health
        elseif priority=="Line of Sight"    then
            local rc=Workspace:Raycast(cam.CFrame.Position,(hrp.Position-cam.CFrame.Position).Unit*maxDist)
            score=(rc and rc.Instance and rc.Instance:IsDescendantOf(c)) and screenDist or math.huge
        end
        if score<bestScore then best=pl; bestScore=score end
    end
    return best
end

local triggerCooldown = 0

RunService.Heartbeat:Connect(function()
    if not flags["triggerbot"] then return end
    local trigKey = flags["trigger_key"]
    if trigKey and not trigKey.active then return end

    local now = tick()
    if now - triggerCooldown < (flags["trigger_delay"] or 0.08) then return end

    local mousePos = UIS:GetMouseLocation()
    local tfov     = flags["trigger_fov"] or 80
    local maxDist  = flags["aim_max_dist"] or 500

    for _, pl in pairs(Players:GetPlayers()) do
        if pl==lp then continue end
        if flags["aim_team_check"] and pl.Team==lp.Team then continue end
        local c   = pl.Character
        local h   = c and c:FindFirstChildOfClass("Humanoid")
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        if not (c and h and hrp and h.Health>0) then continue end

        local sp, onScreen = cam:WorldToViewportPoint(hrp.Position)
        if not onScreen then continue end
        if (Vector2.new(sp.X,sp.Y)-mousePos).Magnitude > tfov then continue end

        local unitRay = cam:ScreenPointToRay(mousePos.X, mousePos.Y)
        local rc = Workspace:Raycast(unitRay.Origin, unitRay.Direction*maxDist)
        if rc and rc.Instance and rc.Instance:IsDescendantOf(c) then
            mouse1press()
            task.delay(0.05, function() mouse1release() end)
            triggerCooldown = now
            break
        end
    end
end)

RunService.RenderStepped:Connect(function()
    local mp      = UIS:GetMouseLocation()
    local vp      = cam.ViewportSize
    local espOn   = flags["esp_on"]
    local rootPos = getRoot() and getRoot().Position

    fovCircle.Position = Vector2.new(mp.X, mp.Y)

    local currentTarget = getTarget()
    silentAimTarget = currentTarget

    if flags["aim_on"] then
        local aimKey = flags["aim_key"]
        if aimKey and aimKey.active and currentTarget and currentTarget.Character then
            local part = currentTarget.Character:FindFirstChild(flags["aim_part"] or "Head")
            if part then
                local smooth = flags["rage_mode"] and 1 or (flags["aim_smooth"] or 0.15)
                if math.random(1,100) <= (flags["aim_hit_chance"] or 100) then
                    local targetPos = part.Position
                    if flags["aim_prediction"] then
                        local hrp = currentTarget.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            targetPos = targetPos + hrp.AssemblyLinearVelocity * (flags["aim_pred_val"] or 0.1)
                        end
                    end
                    cam.CFrame = cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position, targetPos), smooth)
                end
            end
        end
    end

    if flags["xhair_on"] then
        local cx  = vp.X/2
        local cy  = vp.Y/2
        local sz  = flags["xhair_size"]  or 10
        local gap = flags["xhair_gap"]   or 3
        local thk = flags["xhair_thick"] or 2
        local col = flags["xhair_color"] or Color3.new(1,1,1)
        local function setL(l,fx,fy,tx,ty)
            l.From=Vector2.new(fx,fy); l.To=Vector2.new(tx,ty)
            l.Thickness=thk; l.Color=col; l.Visible=true
        end
        setL(xhairLines.top,    cx,       cy-gap-sz, cx,       cy-gap    )
        setL(xhairLines.bottom, cx,       cy+gap,    cx,       cy+gap+sz )
        setL(xhairLines.left,   cx-gap-sz,cy,        cx-gap,   cy        )
        setL(xhairLines.right,  cx+gap,   cy,        cx+gap+sz,cy        )
        xhairLines.dot.Visible  = flags["xhair_dot"]==true
        xhairLines.dot.Position = Vector2.new(cx,cy)
        xhairLines.dot.Color    = col
    else
        for _,l in pairs(xhairLines) do l.Visible=false end
    end

    for pl, d in pairs(espObjects) do
        local c   = pl.Character
        local h   = c and c:FindFirstChildOfClass("Humanoid")
        local hrp = c and c:FindFirstChild("HumanoidRootPart")

        local function hideAll()
            d.box.Visible=false; d.boxFill.Visible=false
            d.nameText.Visible=false; d.distText.Visible=false
            d.hpBG.Visible=false; d.hpBar.Visible=false; d.hpText.Visible=false
            d.tracer.Visible=false; d.snapLine.Visible=false
            for _,l in pairs(d.corners)  do l.Visible=false end
            for _,l in pairs(d.skeleton) do l.Visible=false end
        end

        if not espOn or not c or not h or not hrp or h.Health<=0 then hideAll(); continue end
        if rootPos and (hrp.Position-rootPos).Magnitude>(flags["esp_max_dist"] or 800) then hideAll(); continue end

        local sp, onScreen = cam:WorldToViewportPoint(hrp.Position)
        if not onScreen then hideAll(); continue end

        local topSP = cam:WorldToViewportPoint(hrp.Position+Vector3.new(0, 3,   0))
        local boxH  = math.abs(topSP.Y - sp.Y) * 2
        local boxW  = boxH * 0.6
        local bx    = sp.X - boxW/2
        local by    = sp.Y - boxH/2
        local boxCol = flags["box_color"] or hex("#64B4FF")
        local style  = flags["box_style"] or "Corner Box"

        if flags["box_esp"] then
            if style == "Full Box" then
                for _,l in pairs(d.corners) do l.Visible=false end
                d.box.Size=Vector2.new(boxW,boxH); d.box.Position=Vector2.new(bx,by)
                d.box.Color=boxCol; d.box.Visible=true
            elseif style == "Corner Box" then
                d.box.Visible=false
                local cL = math.min(boxW,boxH)*0.28
                local co = d.corners
                co[1].From=Vector2.new(bx,by);          co[1].To=Vector2.new(bx+cL,by)
                co[2].From=Vector2.new(bx,by);          co[2].To=Vector2.new(bx,by+cL)
                co[3].From=Vector2.new(bx+boxW,by);     co[3].To=Vector2.new(bx+boxW-cL,by)
                co[4].From=Vector2.new(bx+boxW,by);     co[4].To=Vector2.new(bx+boxW,by+cL)
                co[5].From=Vector2.new(bx,by+boxH);     co[5].To=Vector2.new(bx+cL,by+boxH)
                co[6].From=Vector2.new(bx,by+boxH);     co[6].To=Vector2.new(bx,by+boxH-cL)
                co[7].From=Vector2.new(bx+boxW,by+boxH);co[7].To=Vector2.new(bx+boxW-cL,by+boxH)
                co[8].From=Vector2.new(bx+boxW,by+boxH);co[8].To=Vector2.new(bx+boxW,by+boxH-cL)
                for _,l in pairs(co) do l.Color=boxCol; l.Visible=true end
            else
                d.box.Visible=false
                for _,l in pairs(d.corners) do l.Visible=false end
            end
        else
            d.box.Visible=false
            for _,l in pairs(d.corners) do l.Visible=false end
        end

        if flags["box_esp"] and flags["box_fill"] then
            d.boxFill.Size=Vector2.new(boxW,boxH); d.boxFill.Position=Vector2.new(bx,by); d.boxFill.Visible=true
        else d.boxFill.Visible=false end

        if flags["name_esp"] then
            d.nameText.Text=pl.Name; d.nameText.Position=Vector2.new(sp.X,by-14); d.nameText.Visible=true
        else d.nameText.Visible=false end

        if flags["dist_esp"] and rootPos then
            local dist=math.round((hrp.Position-rootPos).Magnitude)
            d.distText.Text=dist.."m"; d.distText.Position=Vector2.new(sp.X,by+boxH+3); d.distText.Visible=true
        else d.distText.Visible=false end

        if flags["hp_esp"] then
            local pct  = math.clamp(h.Health/math.max(h.MaxHealth,1),0,1)
            local hbX  = bx-6
            local barH = boxH*pct
            d.hpBG.Size=Vector2.new(4,boxH); d.hpBG.Position=Vector2.new(hbX,by); d.hpBG.Visible=true
            d.hpBar.Size=Vector2.new(4,barH)
            d.hpBar.Position=Vector2.new(hbX, by+boxH-barH)
            d.hpBar.Color = flags["hp_color_gradient"]
                and Color3.fromRGB(math.round((1-pct)*255),math.round(pct*255),0)
                or  Color3.fromRGB(0,255,0)
            d.hpBar.Visible=true
            if flags["hp_text"] then
                d.hpText.Text=math.floor(h.Health)
                d.hpText.Position=Vector2.new(hbX+2, by+boxH-barH-12)
                d.hpText.Visible=true
            else d.hpText.Visible=false end
        else
            d.hpBG.Visible=false; d.hpBar.Visible=false; d.hpText.Visible=false
        end

        if flags["tracers_on"] then
            local origin = flags["tracer_origin"] or "Bottom"
            local fromX  = origin=="Mouse" and mp.X or vp.X/2
            local fromY  = origin=="Top"    and 0
                        or origin=="Center" and vp.Y/2
                        or origin=="Mouse"  and mp.Y
                        or vp.Y
            d.tracer.From=Vector2.new(fromX,fromY)
            d.tracer.To=Vector2.new(sp.X,sp.Y)
            d.tracer.Thickness=flags["tracer_thick"] or 1
            d.tracer.Visible=true
        else d.tracer.Visible=false end

        if flags["snap_line"] and currentTarget==pl then
            d.snapLine.From=Vector2.new(vp.X/2,vp.Y/2)
            d.snapLine.To=Vector2.new(sp.X,sp.Y)
            d.snapLine.Thickness=flags["snap_thickness"] or 1
            d.snapLine.Visible=true
        else d.snapLine.Visible=false end

        if flags["skel_esp"] then
            local skelCol = flags["skel_color"] or hex("#AA55EB")
            for i,pair in ipairs(SKEL_PAIRS) do
                local p1 = c:FindFirstChild(pair[1])
                local p2 = c:FindFirstChild(pair[2])
                local ln = d.skeleton[i]
                if p1 and p2 then
                    local s1,on1 = cam:WorldToViewportPoint(p1.Position)
                    local s2,on2 = cam:WorldToViewportPoint(p2.Position)
                    if on1 and on2 then
                        ln.From=Vector2.new(s1.X,s1.Y); ln.To=Vector2.new(s2.X,s2.Y)
                        ln.Color=skelCol; ln.Visible=true
                    else ln.Visible=false end
                else ln.Visible=false end
            end
        else
            for _,l in pairs(d.skeleton) do l.Visible=false end
        end
    end
end)

