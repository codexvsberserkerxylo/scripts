local espObjects = {}

local function buildESP(pl)
    if pl == lp then return end
    local corners = {}
    for i = 1, 8 do
        corners[i] = newDraw("Line", {Thickness=2, Visible=false, Color=hex("#64B4FF")})
    end
    local skeleton = {}
    for i = 1, #SKEL_PAIRS do
        skeleton[i] = newDraw("Line", {Thickness=1, Visible=false, Color=hex("#AA55EB")})
    end
    espObjects[pl] = {
        box      = newDraw("Square", {Thickness=1, Filled=false,  Visible=false, Color=hex("#64B4FF")}),
        boxFill  = newDraw("Square", {Filled=true,  Visible=false, Color=hex("#64B4FF"), Transparency=0.6}),
        corners  = corners,
        nameText = newDraw("Text",   {Size=13, Center=true, Outline=true, Visible=false, Color=Color3.new(1,1,1), Font=2}),
        distText = newDraw("Text",   {Size=11, Center=true, Outline=true, Visible=false, Color=Color3.fromRGB(180,180,180), Font=2}),
        hpBG     = newDraw("Square", {Filled=true,  Visible=false, Color=Color3.new(0,0,0)}),
        hpBar    = newDraw("Square", {Filled=true,  Visible=false, Color=Color3.fromRGB(0,255,0)}),
        hpText   = newDraw("Text",   {Size=10, Center=true, Outline=true, Visible=false, Color=Color3.new(1,1,1), Font=2}),
        tracer   = newDraw("Line",   {Thickness=1, Visible=false, Color=Color3.new(1,1,1)}),
        snapLine = newDraw("Line",   {Thickness=1, Visible=false, Color=hex("#64B4FF")}),
        skeleton = skeleton,
    }
end

local function destroyESP(pl)
    local d = espObjects[pl]
    if not d then return end
    for k, v in pairs(d) do
        if k == "corners" or k == "skeleton" then
            for _, l in pairs(v) do pcall(function() l:Remove() end) end
        else
            pcall(function() v:Remove() end)
        end
    end
    espObjects[pl] = nil
end

for _, pl in pairs(Players:GetPlayers()) do buildESP(pl) end
Players.PlayerAdded:Connect(buildESP)
Players.PlayerRemoving:Connect(destroyESP)

local silentAimTarget = nil

local oldIndex
oldIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
    if not checkcaller() then
        local ok, isMouseResult = pcall(function()
            return typeof(self) == "Instance" and self:IsA("Mouse")
        end)
        if ok and isMouseResult and flags["silent_aim"] then
            local target = silentAimTarget
            if target and target.Character then
                local part = target.Character:FindFirstChild(flags["aim_part"] or "Head")
                if part then
                    if key == "Hit" then
                        return CFrame.new(part.Position)
                    elseif key == "Target" then
                        return part
                    end
                end
            end
        end
    end
    return oldIndex(self, key)
end))

