local function isEnemyPlayer(pl)
    if not flags["aim_team_check"] then return true end
    return pl.Team ~= lp.Team
end

RunService.RenderStepped:Connect(function()
    if not flags["triggerbot"] or not triggerAlive then return end
    local trigKey = flags["trigger_key"]
    if trigKey and not trigKey.active then return end

    local now = tick()
    if now - triggerCooldown < (flags["trigger_delay"] or 0.08) then return end


    local tgt = mouse.Target
    if tgt and tgt.Parent then
        local h = tgt.Parent:FindFirstChild("Humanoid")
        if h and tgt.Parent.Name ~= lp.Name and h.Health > 0 then
            local targetPl = Players:FindFirstChild(tgt.Parent.Name)
            if targetPl and isEnemyPlayer(targetPl) then
                mouse1press()
                task.delay(flags["trigger_delay"] or 0.08, function() mouse1release() end)
                triggerCooldown = now
                return
            end
        end
    end


    if flags["wallbang"] then
        local mousePos = UIS:GetMouseLocation()
        local tfov = flags["trigger_fov"] or 80
        for _, pl in pairs(Players:GetPlayers()) do
            if pl == lp then continue end
            if not isEnemyPlayer(pl) then continue end
            local c = pl.Character
            local h = c and c:FindFirstChildOfClass("Humanoid")
            local hrp = c and c:FindFirstChild("HumanoidRootPart")
            if not (c and h and hrp and h.Health > 0) then continue end
            local sp, onScreen = cam:WorldToViewportPoint(hrp.Position)
            if not onScreen then continue end
            if (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude > tfov then continue end
            mouse1press()
            task.delay(flags["trigger_delay"] or 0.08, function() mouse1release() end)
            triggerCooldown = now
            break
        end
    end
end)



