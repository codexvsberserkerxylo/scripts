    local function getShuffledEnemies()
        local list = {}
        for _,pl in pairs(Players:GetPlayers()) do
            if pl == lp then continue end
            if flags["kill_team_check"] and pl.Team == lp.Team then continue end
            table.insert(list, pl)
        end
        for i = #list, 2, -1 do
            local j = math.random(1, i)
            list[i], list[j] = list[j], list[i]
        end
        return list
    end

    local function runKillAll()
        while killAllActive do
            local enemies = getShuffledEnemies()
            if #enemies == 0 then task.wait(0.5); continue end

            for _, target in ipairs(enemies) do
                if not killAllActive then return end

                local deadline = tick() + 4
                while killAllActive and tick() < deadline do
                    local c   = target.Character
                    local h   = c and c:FindFirstChildOfClass("Humanoid")
                    local hrp = c and c:FindFirstChild("HumanoidRootPart")
                    if c and h and hrp and h.Health > 0 then break end
                    task.wait(0.1)
                end

                while killAllActive do
                    local r   = getRoot()
                    local c   = target.Character
                    local h   = c and c:FindFirstChildOfClass("Humanoid")
                    local hrp = c and c:FindFirstChild("HumanoidRootPart")
                    if not r or not c or not h or not hrp or h.Health <= 0 then break end
                    r.CFrame = hrp.CFrame * CFrame.new(0, 0, 2.2)
                    task.wait(flags["kill_delay"] or 0.06)
                end

                task.wait(0.1)
            end
        end
    end

