    local killAllThread = nil

    local function isPlayerAlive(pl)
        local c = pl.Character
        local h = c and c:FindFirstChildOfClass("Humanoid")
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        return (c ~= nil) and (h ~= nil) and (hrp ~= nil) and (h.Health > 0)
    end

    local function getAliveEnemies()
        local list = {}
        for _, pl in pairs(Players:GetPlayers()) do
            if pl == lp then continue end
            if flags["kill_team_check"] and pl.Team == lp.Team then continue end
            if isPlayerAlive(pl) then table.insert(list, pl) end
        end
        for i =
            local j = math.random(1, i); list[i], list[j] = list[j], list[i]
        end
        return list
    end

    local function runKillAll()
        while killAllActive do
            local enemies = getAliveEnemies()
            if

            for _, target in ipairs(enemies) do
                if not killAllActive then return end

                local spawnDeadline = tick() + 4
                while killAllActive and tick() < spawnDeadline do
                    if isPlayerAlive(target) then break end
                    task.wait(0.1)
                end

                if not isPlayerAlive(target) then continue end

                local engageStart = tick()
                local maxEngage = flags["kill_engage_time"] or 4

                while killAllActive do
                    local r = getRoot()
                    local c = target.Character
                    local h = c and c:FindFirstChildOfClass("Humanoid")
                    local hrp = c and c:FindFirstChild("HumanoidRootPart")
                    local head = c and c:FindFirstChild("Head")

                    if not r or not c or not h or not hrp then break end
                    if h.Health <= 0 then break end
                    if tick() - engageStart > maxEngage then break end

                    r.CFrame = hrp.CFrame * CFrame.new(0, 0, 5)

                    if head then
                        local aimPos = head.Position
                        if flags["aim_prediction"] and hrp then
                            aimPos = aimPos + hrp.AssemblyLinearVelocity * (flags["aim_pred_val"] or 0.1)
                        end
                        cam.CFrame = CFrame.lookAt(cam.CFrame.Position, aimPos)
                    end

                    task.wait(flags["kill_delay"] or 0.06)
                end

                task.wait(0.1)
            end
        end
    end

