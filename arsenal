        local obj = w:FindFirstChild(name)
        if obj and origWeaponVals[w][name] == nil then
            origWeaponVals[w][name] = obj.Value
        end
    end
    local function restoreWV(w, name)
        local obj = w:FindFirstChild(name)
        if obj and origWeaponVals[w] and origWeaponVals[w][name] ~= nil then
