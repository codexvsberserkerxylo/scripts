end)








local silentAimTarget = nil
local silentAimBodyPart = nil


local function findClosestPartFromCursor()
    local mousePos = UIS:GetMouseLocation()
    local closestDist = math.huge
    local closest = nil

    for _, pl in pairs(Players:GetPlayers()) do
        if pl == lp then continue end
        if flags["aim_team_check"] and pl.Team == lp.Team then continue end
        local c = pl.Character
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if not (c and h and h.Health > 0) then continue end

        for _, part in pairs(c:GetChildren()) do
            if part:IsA("BasePart") then
                local sp, onScreen = cam:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = part
                    end
                end
            end
        end
    end

    silentAimBodyPart = closest
end

RunService:BindToRenderStep("__lx_silentPartFinder", 120, function()
    if flags["silent_aim"] then
        findClosestPartFromCursor()
    else
        silentAimBodyPart = nil
    end
end)



local oldNameCall
oldNameCall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if not checkcaller() and flags["silent_aim"] and silentAimBodyPart and silentAimBodyPart.Parent then
        if method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRay" then
            args[1] = Ray.new(
                cam.CFrame.Position,
                (silentAimBodyPart.Position - cam.CFrame.Position).Unit * 600
            )
            return oldNameCall(self, unpack(args))
        end
    end
    return oldNameCall(self, ...)
end))


local oldIndex
oldIndex = hookmetamethod(game, "__index", newcclosure(function(self, key)
    if not checkcaller() then
        local ok, isMouse = pcall(function()
            return typeof(self) == "Instance" and self:IsA("Mouse")
        end)
        if ok and isMouse and flags["silent_aim"] and silentAimTarget then
            local t = silentAimTarget
            if t and t.Character then
                local h = t.Character:FindFirstChildOfClass("Humanoid")
                if h and h.Health > 0 then
                    local part = t.Character:FindFirstChild(flags["aim_part"] or "Head")
                        or t.Character:FindFirstChild("HumanoidRootPart")
                    if part then
                        if key == "Hit" then return CFrame.new(part.Position) end
                        if key == "Target" then return part end
                        if key == "UnitRay" then
                            return Ray.new(
                                cam.CFrame.Position,
                                (part.Position - cam.CFrame.Position).Unit * 1000
                            )
                        end
                    end
                end
            end
        end
    end
    return oldIndex(self, key)
end))


local skinColors = {arm=Color3.fromRGB(50,50,50), gun=Color3.fromRGB(50,50,50)}
