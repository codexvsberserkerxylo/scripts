local function refreshPickupESP()
    cleanupPickupESP()
    local debris = Workspace:FindFirstChild("Debris")
    if not debris then return end
    for _, v in pairs(debris:GetChildren()) do
        local isAmmo = v.Name == "DeadAmmo" and pickupESPEnabled.ammo
        local isHP = v.Name == "DeadHP" and pickupESPEnabled.hp
        if isAmmo or isHP then
            buildPickupESPFor(v)
        end
    end
end


local function applyChams(pl)
    if pl == lp then return end
    local c = pl.Character
    if not c then return end
    local mat = Enum.Material[flags["chams_material"] or "Neon"]
    for _, p in pairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function()

                if not p:GetAttribute("__lx_mat") then
                    p:SetAttribute("__lx_mat", p.Material.Name)
                    p:SetAttribute("__lx_colR", p.Color.R)
                    p:SetAttribute("__lx_colG", p.Color.G)
                    p:SetAttribute("__lx_colB", p.Color.B)
                end
                p.Material = mat
                p.Color = colors.chams
            end)
        end
    end
end

local function removeChams(pl)
    local c = pl and pl.Character
    if not c then return end
    for _, p in pairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
            pcall(function()
                local m = p:GetAttribute("__lx_mat")
                local cr = p:GetAttribute("__lx_colR")
                local cg = p:GetAttribute("__lx_colG")
                local cb = p:GetAttribute("__lx_colB")
                if m then
                    p.Material = Enum.Material[m]
                    p:SetAttribute("__lx_mat", nil)
                end
                if cr ~= nil and cg ~= nil and cb ~= nil then
                    p.Color = Color3.new(cr, cg, cb)
                    p:SetAttribute("__lx_colR", nil)
                    p:SetAttribute("__lx_colG", nil)
                    p:SetAttribute("__lx_colB", nil)
                end
            end)
        end
    end
end

local function reapplyAllChams()
    for _, pl in pairs(Players:GetPlayers()) do
        if pl ~= lp then
            if flags["chams_on"] then applyChams(pl) else removeChams(pl) end
        end
    end
end

local hitboxOrigSizes = {}
local HITBOX_PARTS = {"Head","UpperTorso","LowerTorso","HumanoidRootPart","LeftUpperArm","RightUpperArm","LeftUpperLeg","RightUpperLeg"}

local function expandHitbox(pl)
    if pl == lp then return end
    local c = pl.Character
    if not c then return end
    if not hitboxOrigSizes[pl] then hitboxOrigSizes[pl] = {} end
    local sz = flags["hitbox_size"] or 8
    for _, partName in ipairs(HITBOX_PARTS) do
        local part = c:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            if not hitboxOrigSizes[pl][partName] then
                hitboxOrigSizes[pl][partName] = part.Size
            end
            pcall(function() part.Size = Vector3.new(sz, sz, sz) end)
        end
    end
end

local function restoreHitbox(pl)
    local data = hitboxOrigSizes[pl]
    if not data then return end
    local c = pl and pl.Character
    if c then
        for partName, origSize in pairs(data) do
            local part = c:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                pcall(function() part.Size = origSize end)
            end
        end
    end
    hitboxOrigSizes[pl] = nil
end

local function updateAllHitboxes()
    local active = flags["hitbox_on"] or flags["silent_aim"]
    for _, pl in pairs(Players:GetPlayers()) do
        if pl ~= lp then
            if active then expandHitbox(pl) else restoreHitbox(pl) end
        end
    end
end


