local function hookTriggerHumanoid(char)
    local h = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5)
    if h then h.HealthChanged:Connect(function(hp) triggerAlive = hp > 0 end) end
    triggerAlive = true
end

