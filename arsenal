local armSkinOn = false
local gunSkinOn = false
local rainbowOn = false
local rainbowHue = 0

local function applyArmSkin()
    local arms = Workspace.Camera:FindFirstChild("Arms")
    if not arms then return end
    for _, v in pairs(arms:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "Right Arm" or v.Name == "Left Arm"
            or v.Name == "RightHand" or v.Name == "LeftHand"
            or v.Name == "RightArm" or v.Name == "LeftArm") then
            pcall(function()
                v.Material = Enum.Material[skinMats.arm]
                v.Color = skinColors.arm
            end)
        end
    end
end

local function applyGunSkin()
    local arms = Workspace.Camera:FindFirstChild("Arms")
    if not arms then return end
    for _, v in pairs(arms:GetDescendants()) do
        if v:IsA("MeshPart") then
            pcall(function()
                v.Material = Enum.Material[skinMats.gun]
                v.Color = skinColors.gun
            end)
        end
    end
end

RunService.RenderStepped:Connect(function()
    if armSkinOn then applyArmSkin() end
    if gunSkinOn and not rainbowOn then applyGunSkin() end
    if rainbowOn then
        rainbowHue = (rainbowHue + 0.005) % 1
        local arms = Workspace.Camera:FindFirstChild("Arms")
        if arms then
            for _, v in pairs(arms:GetDescendants()) do
                if v:IsA("MeshPart") then
                    pcall(function() v.Color = Color3.fromHSV(rainbowHue, 1, 1) end)
                end
            end
        end
    end
end)


