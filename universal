-- skeleton bone connections for R15 and R6
local R15 = {
	{"Head","UpperTorso"},
	{"UpperTorso","LowerTorso"},
	{"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
	{"UpperTorso","LeftUpperArm"}, {"LeftUpperArm","LeftLowerArm"}, {"LeftLowerArm","LeftHand"},
	{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
	{"LowerTorso","LeftUpperLeg"}, {"LeftUpperLeg","LeftLowerLeg"}, {"LeftLowerLeg","LeftFoot"},
}
local R6 = {
	{"Head","Torso"},
	{"Torso","Right Arm"},{"Torso","Left Arm"},
	{"Torso","Right Leg"},{"Torso","Left Leg"},
}

local function sameTeam(pl)
	if not lp.Team then return false end
	return pl.Team == lp.Team
end

-- linear prediction: where the target will be by the time bullet arrives
local function predicted(part)
	if not S.predOn then return part.Position end
	local vel  = part.AssemblyLinearVelocity
	local dist = (part.Position - cam.CFrame.Position).Magnitude
	local t    = dist / math.max(S.bulletSpeed, 1)
	return part.Position + vel * t
end

local function targets()
	local out = {}
	local r = root()
	if not r then return out end
	for _,pl in Players:GetPlayers() do
		if pl == lp or sameTeam(pl) then continue end
		local c = pl.Character
		if not c then continue end
		local h = c:FindFirstChildOfClass("Humanoid")
		if not h or h.Health <= 0 then continue end
		local part = c:FindFirstChild(S.tPart) or c:FindFirstChild("HumanoidRootPart")
		if not part then continue end
		local pred    = predicted(part)
		local s, front = toScreen(pred)
		if not front then continue end
		if (s - mid()).Magnitude > S.fovR then continue end
		local d3 = (part.Position - r.Position).Magnitude
		if d3 > S.maxDist then continue end
		table.insert(out, {pl=pl, part=part, pred=pred, d2=(s-mid()).Magnitude, d3=d3, hp=h.Health})
	end
	return out
end

local function bestTarget()
	local list = targets()
	if #list == 0 then return nil end
	if     S.priority == "Nearest"   then table.sort(list, function(a,b) return a.d2 < b.d2  end)
	elseif S.priority == "Lowest HP" then table.sort(list, function(a,b) return a.hp < b.hp  end)
	elseif S.priority == "Random"    then return list[math.random(1,#list)] end
	return list[1]
end

-- drawing pool
local pool = {}
local function get(uid, k, ctor)
	local key = uid.."_"..k
	if not pool[key] then pool[key] = ctor() end
	return pool[key]
end
local function hidePlayer(uid)
	for k,d in pairs(pool) do
		if k:sub(1,#uid+1) == uid.."_" then d.Visible = false end
	end
end
local function hideAll()
	for _,d in pairs(pool) do d.Visible = false end
end

-- Transparency: 0 = invisible, 1 = fully visible
local function newLine(col, thick)
	local d = Drawing.new("Line")
	d.Visible=false d.Thickness=thick or 1
	d.Color=col or Color3.fromRGB(255,80,80) d.Transparency=1
	return d
end
local function newRect(filled, col, alpha)
	local d = Drawing.new("Square")
	d.Visible=false d.Thickness=1 d.Filled=filled or false
	d.Color=col or Color3.fromRGB(255,80,80) d.Transparency=alpha or 1
	return d
end
local function newTxt(sz, col)
	local d = Drawing.new("Text")
	d.Visible=false d.Size=sz or 14
	d.Color=col or Color3.fromRGB(255,255,255)
	d.Outline=true d.Center=true d.Font=2 d.Transparency=1
	return d
end

