local function drawPlayer(pl)
	local uid = tostring(pl.UserId)
	local c   = pl.Character
	if not c then hidePlayer(uid) return end
	local h = c:FindFirstChildOfClass("Humanoid")
	if not h or h.Health <= 0 then hidePlayer(uid) return end
	local hrp = c:FindFirstChild("HumanoidRootPart")
	if not hrp then hidePlayer(uid) return end

	local head = c:FindFirstChild("Head")
	local topY = head and (head.Position.Y + 0.7) or (hrp.Position.Y + h.HipHeight + 1.2)
	local botY = hrp.Position.Y - h.HipHeight - 0.2
	local topP = Vector3.new(hrp.Position.X, topY, hrp.Position.Z)
	local botP = Vector3.new(hrp.Position.X, botY, hrp.Position.Z)

	local topVP = cam:WorldToViewportPoint(topP)
	local botVP = cam:WorldToViewportPoint(botP)
	if topVP.Z <= 0 then hidePlayer(uid) return end

	local top2 = Vector2.new(topVP.X, topVP.Y)
	local bot2 = Vector2.new(botVP.X, botVP.Y)
	local bh   = math.abs(bot2.Y - top2.Y)
	if bh < 5 then hidePlayer(uid) return end
	local bw = bh * 0.55
	local bx = top2.X - bw * 0.5
	local by = top2.Y

	local r    = root()
	local dist = r and (hrp.Position - r.Position).Magnitude or 0

	-- full box
	if S.boxESP then
		local b = get(uid,"box", function() return newBox(false, ACCENT, 1) end)
		b.Color    = ACCENT
		b.Position = Vector2.new(bx, by)
		b.Size     = Vector2.new(bw, bh)
		b.Visible  = true
	else
		local b = pool[uid.."_box"] if b then b.Visible=false end
	end

	-- corner box: L-brackets at each corner instead of full rect
	if S.cornerBox then
		local cl = math.floor(bw * 0.25)
		local corners = {
			{k="ctlh", x1=bx,    y1=by,    x2=bx+cl, y2=by},
			{k="ctlv", x1=bx,    y1=by,    x2=bx,    y2=by+cl},
			{k="ctrh", x1=bx+bw, y1=by,    x2=bx+bw-cl, y2=by},
			{k="ctrv", x1=bx+bw, y1=by,    x2=bx+bw,    y2=by+cl},
			{k="cblh", x1=bx,    y1=by+bh, x2=bx+cl,    y2=by+bh},
			{k="cblv", x1=bx,    y1=by+bh, x2=bx,       y2=by+bh-cl},
			{k="cbrh", x1=bx+bw, y1=by+bh, x2=bx+bw-cl, y2=by+bh},
			{k="cbrv", x1=bx+bw, y1=by+bh, x2=bx+bw,    y2=by+bh-cl},
		}
		for _,co in ipairs(corners) do
			local ln = get(uid, co.k, function() return newLine(ACCENT, 2) end)
			ln.Color = ACCENT
			ln.From  = Vector2.new(co.x1, co.y1)
			ln.To    = Vector2.new(co.x2, co.y2)
			ln.Visible = true
		end
	else
		for _,k in ipairs({"ctlh","ctlv","ctrh","ctrv","cblh","cblv","cbrh","cbrv"}) do
			local d = pool[uid.."_"..k] if d then d.Visible=false end
		end
	end

	-- skeleton: lines between actual body part positions, works through walls
	if S.skeleton then
		local isR15 = c:FindFirstChild("UpperTorso") ~= nil
		local bones = isR15 and R15_BONES or R6_BONES
		for i, pair in ipairs(bones) do
			local p1 = c:FindFirstChild(pair[1])
			local p2 = c:FindFirstChild(pair[2])
			if p1 and p2 then
				local s1, f1 = vp2s(p1.Position)
				local s2, f2 = vp2s(p2.Position)
				if f1 and f2 then
					-- glow underneath
					local gl = get(uid,"bng"..i, function() return newLine(Color3.fromRGB(255,80,80), 4) end)
					gl.Color=Color3.fromRGB(255,80,80) gl.Transparency=0.25
					gl.From=s1 gl.To=s2 gl.Visible=true
					-- actual bone line
					local ln = get(uid,"bn"..i, function() return newLine(Color3.fromRGB(255,200,200), 1.5) end)
					ln.Color=Color3.fromRGB(255,200,200)
					ln.From=s1 ln.To=s2 ln.Visible=true
				else
					for _,bk in ipairs({"bn"..i,"bng"..i}) do
						local d=pool[uid.."_"..bk] if d then d.Visible=false end
					end
				end
			else
				for _,bk in ipairs({"bn"..i,"bng"..i}) do
					local d=pool[uid.."_"..bk] if d then d.Visible=false end
				end
			end
		end
		-- hide leftover bone slots when switching R15→R6
		for i=#bones+1, #R15_BONES do
			for _,bk in ipairs({"bn"..i,"bng"..i}) do
				local d=pool[uid.."_"..bk] if d then d.Visible=false end
			end
		end
	else
		for i=1, #R15_BONES do
			for _,bk in ipairs({"bn"..i,"bng"..i}) do
				local d=pool[uid.."_"..bk] if d then d.Visible=false end
			end
		end
	end

	if S.tracers then
		local tr = get(uid,"tr", function() return newLine(ACCENT, 1) end)
		tr.Color   = ACCENT
		tr.From    = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
		tr.To      = bot2
		tr.Visible = true
	else
		local t = pool[uid.."_tr"] if t then t.Visible=false end
	end

	local nameOff = 0
	if S.nameESP then
		local nm = get(uid,"nm", function() return newText(14, Color3.fromRGB(255,255,255)) end)
		nm.Text     = pl.Name
		nm.Position = Vector2.new(top2.X, top2.Y - 18)
		nm.Visible  = true
		nameOff     = 15
	else
		local n = pool[uid.."_nm"] if n then n.Visible=false end
	end

	if S.distESP then
		local dt = get(uid,"dt", function() return newText(12, Color3.fromRGB(160,200,255)) end)
		dt.Text     = math.floor(dist).."m"
		dt.Position = Vector2.new(top2.X, top2.Y - 18 - nameOff)
		dt.Visible  = true
	else
		local d = pool[uid.."_dt"] if d then d.Visible=false end
	end

	if S.healthESP then
		local pct  = math.clamp(h.Health / math.max(h.MaxHealth,1), 0, 1)
		local barX = bx - 6
		local bg   = get(uid,"hbg", function() return newBox(true, Color3.fromRGB(20,20,20), 1) end)
		bg.Position = Vector2.new(barX, by)
		bg.Size     = Vector2.new(4, bh)
		bg.Visible  = true
		local fg = get(uid,"hfg", function()
			local d = Drawing.new("Square")
			d.Filled=true d.Transparency=1 d.Visible=false
			return d
		end)
		local fh  = bh * pct
		fg.Color    = Color3.fromRGB(math.floor(255*(1-pct)), math.floor(220*pct), 30)
		fg.Position = Vector2.new(barX, by + (bh - fh))
		fg.Size     = Vector2.new(4, math.max(fh, 1))
		fg.Visible  = true
	else
		for _,k in ipairs({"hbg","hfg"}) do
			local d = pool[uid.."_"..k] if d then d.Visible=false end
		end
	end
end

local spinAngle = 0

RunService.RenderStepped:Connect(function(dt)
	fovCircle.Position = mid()
	fovCircle.Radius   = S.fovR
	fovCircle.Color    = ACCENT
	fovCircle.Visible  = S.showFov and (S.aimbotOn or S.silentOn)

	if S.aimbotOn and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		local t = bestTarget()
		if t then
			local s2d   = vp2s(t.part.Position)
			local delta = s2d - mid()
			local f     = math.clamp(1 - S.smooth/100, 0.02, 1)
			moveMouseBy(delta.X * f, delta.Y * f)
		end
	end

	if S.espOn then
		for _,pl in Players:GetPlayers() do
			if pl ~= lp then drawPlayer(pl) end
		end
	else
		hideAll()
	end

	if S.spinOn then
		spinAngle += S.spinSpd * dt
		local r = root()
		if r then
			r.CFrame = CFrame.new(r.CFrame.Position) * CFrame.Angles(0, math.rad(spinAngle), 0)
		end
	end
end)

-- kill aura: fires weapon remote at everyone within range
local lastAura = 0
RunService.Heartbeat:Connect(function()
	if not S.killAura then return end
	if tick()-lastAura < S.killDelay then return end
	lastAura = tick()
	local c = char() if not c then return end
	local r = root() if not r then return end
	local tool   = c:FindFirstChildWhichIsA("Tool")
	local remote = findRemote(tool)
	if not remote then return end
	for _,pl in Players:GetPlayers() do
		if pl==lp or sameTeam(pl) then continue end
		local ec = pl.Character if not ec then continue end
		local eh = ec:FindFirstChildOfClass("Humanoid")
		if not eh or eh.Health<=0 then continue end
		local hrp = ec:FindFirstChild("HumanoidRootPart") if not hrp then continue end
		if (hrp.Position-r.Position).Magnitude > S.killDist then continue end
		local pos = hrp.Position
		local dir = (pos - cam.CFrame.Position).Unit
		pcall(function() remote:FireServer(pos, dir) end)
		pcall(function() remote:FireServer(CFrame.new(pos, pos+dir)) end)
		pcall(function() remote:FireServer(hrp) end)
	end
end)

-- namecall hook for silent aim — catches FireServer at metamethod level
-- setreadonly unlocks the protected metatable without triggering the readonly error
local mt    = getrawmetatable(game)
local oldNC = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
	local method = getnamecallmethod()
	if method == "FireServer" and S.silentOn then
		local t = bestTarget()
		if t and math.random(1,100) <= S.hitChance then
			local args = {...}
			local pos  = t.part.Position
			local dir  = (pos - cam.CFrame.Position).Unit
			local hit  = 0
			for i,v in ipairs(args) do
				if typeof(v) == "Vector3" then
					if hit==0 then args[i]=pos
					elseif hit==1 then args[i]=dir end
					hit += 1
					if hit >= 2 then break end
				elseif typeof(v) == "CFrame" then
					args[i] = CFrame.new(pos) * CFrame.Angles(0, math.atan2(-dir.X,-dir.Z), 0)
					break
				elseif typeof(v) == "Instance" and v:IsA("BasePart") then
					args[i] = t.part break
				end
			end
			return oldNC(self, table.unpack(args))
		end
	end
	return oldNC(self, ...)
end)
setreadonly(mt, true)

local flyConn, bVel, bGyro

local function stopFly()
	if flyConn then flyConn:Disconnect() flyConn=nil end
	if bVel    then bVel:Destroy()       bVel=nil    end
	if bGyro   then bGyro:Destroy()      bGyro=nil   end
end

local function startFly()
	stopFly()
	local r = root()
	if not r then return end
	bVel          = Instance.new("BodyVelocity", r)
	bVel.Velocity = Vector3.zero
	bVel.MaxForce = Vector3.new(1e5,1e5,1e5)
	bGyro           = Instance.new("BodyGyro", r)
	bGyro.MaxTorque = Vector3.new(1e5,1e5,1e5)
	bGyro.P         = 1e4
	flyConn = RunService.RenderStepped:Connect(function()
		if not S.flyOn then stopFly() return end
		local r2 = root()
		if not r2 then stopFly() return end
		local dir = Vector3.zero
		if UIS:IsKeyDown(Enum.KeyCode.W)         then dir += cam.CFrame.LookVector  end
		if UIS:IsKeyDown(Enum.KeyCode.S)         then dir -= cam.CFrame.LookVector  end
		if UIS:IsKeyDown(Enum.KeyCode.A)         then dir -= cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D)         then dir += cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.Space)     then dir += Vector3.new(0,1,0)     end
		if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.new(0,1,0)     end
		bVel.Velocity = dir.Magnitude > 0 and dir.Unit * S.flySpd or Vector3.zero
		bGyro.CFrame  = cam.CFrame
	end)
end

local noclipConn
local function setNoclip(v)
	if noclipConn then noclipConn:Disconnect() noclipConn=nil end
	if not v then
		local c = char()
		if c then for _,p in c:GetDescendants() do if p:IsA("BasePart") then p.CanCollide=true end end end
		return
	end
	noclipConn = RunService.Stepped:Connect(function()
		if not S.noclipOn then noclipConn:Disconnect() noclipConn=nil return end
		local c = char()
		if not c then return end
		for _,p in c:GetDescendants() do if p:IsA("BasePart") then p.CanCollide=false end end
	end)
end

local godConn
local function setGod(v)
	if godConn then godConn:Disconnect() godConn=nil end
	local h = hum()
	if not v then if h then h.MaxHealth=100 h.Health=100 end return end
	if h then h.MaxHealth=math.huge h.Health=math.huge end
	godConn = RunService.Heartbeat:Connect(function()
		if not S.godMode then godConn:Disconnect() godConn=nil return end
		local h2 = hum()
		if h2 then h2.Health=h2.MaxHealth end
	end)
end

local freezeConn, frozenCF
local function setFreeze(v)
	if freezeConn then freezeConn:Disconnect() freezeConn=nil end
	local r = root()
	if not v then if r then r.Anchored=false end return end
	if r then
		frozenCF   = r.CFrame
		r.Anchored = true
		freezeConn = RunService.Heartbeat:Connect(function()
			if not S.frozen then freezeConn:Disconnect() freezeConn=nil return end
			local r2 = root()
			if r2 then r2.CFrame=frozenCF end
		end)
	end
end

