fovCircle.Visible=false fovCircle.Radius=S.fovR
fovCircle.Color=Color3.fromRGB(255,255,255)
fovCircle.Thickness=1 fovCircle.Filled=false fovCircle.Transparency=1

-- actual top/bottom of the char using head position so the box fits properly
local function charBounds(c, hrp, h)
	local head = c:FindFirstChild("Head")
	local topP = head
		and Vector3.new(hrp.Position.X, head.Position.Y + 0.75, hrp.Position.Z)
		or  hrp.Position + Vector3.new(0, h.HipHeight + 1.6, 0)
	local botP = hrp.Position - Vector3.new(0, h.HipHeight + 0.2, 0)
	return topP, botP
end

local function drawPlayer(pl)
	local uid = tostring(pl.UserId)
	local c   = pl.Character
	if not c then hidePlayer(uid) return end
	local h   = c:FindFirstChildOfClass("Humanoid")
	if not h or h.Health <= 0 then hidePlayer(uid) return end
	local hrp = c:FindFirstChild("HumanoidRootPart")
	if not hrp then hidePlayer(uid) return end

	local topW, botW = charBounds(c, hrp, h)

	local topVP = cam:WorldToViewportPoint(topW)
	local botVP = cam:WorldToViewportPoint(botW)
	if topVP.Z <= 0 then hidePlayer(uid) return end

	local top2 = Vector2.new(topVP.X, topVP.Y)
	local bot2 = Vector2.new(botVP.X, botVP.Y)

	local bh = math.abs(top2.Y - bot2.Y)
	if bh < 4 then hidePlayer(uid) return end

	-- wider box so it actually covers arms (0.68 instead of 0.45)
	local bw = bh * 0.68
	local bx = top2.X - bw*0.5
	local by = top2.Y

	local r    = root()
	local dist = r and (hrp.Position - r.Position).Magnitude or 0

	-- box esp
	if S.boxESP then
		local b = get(uid,"box",function() return newRect(false, Color3.fromRGB(255,60,60), 1) end)
		b.Position = Vector2.new(bx, by)
		b.Size     = Vector2.new(bw, bh)
		b.Visible  = true
	else
		local b = pool[uid.."_box"] if b then b.Visible=false end
	end

	-- skeleton wallhack: lines between actual body parts
	if S.wallhack then
		local isR15 = c:FindFirstChild("UpperTorso") ~= nil
		local skel  = isR15 and R15 or R6
		for i, pair in ipairs(skel) do
			local p1 = c:FindFirstChild(pair[1])
			local p2 = c:FindFirstChild(pair[2])
			local key = "sk"..i
			if p1 and p2 then
				local s1, f1 = toScreen(p1.Position)
				local s2, f2 = toScreen(p2.Position)
				if f1 and f2 then
					local ln = get(uid, key, function() return newLine(Color3.fromRGB(255,80,80), 1.5) end)
					ln.From=s1 ln.To=s2 ln.Visible=true
				else
					local ln = pool[uid.."_"..key] if ln then ln.Visible=false end
				end
			else
				local ln = pool[uid.."_sk"..i] if ln then ln.Visible=false end
			end
		end
	else
		for i=1,#R15 do
			local ln = pool[uid.."_sk"..i] if ln then ln.Visible=false end
		end
	end

	-- tracer from bottom of screen to feet
	if S.tracers then
		local tr = get(uid,"tr",function() return newLine(Color3.fromRGB(255,200,0), 1) end)
		tr.From=Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
		tr.To=bot2 tr.Visible=true
	else
		local t = pool[uid.."_tr"] if t then t.Visible=false end
	end

	-- name above head, 15px
	local nameOff = 0
	if S.nameESP then
		local nm = get(uid,"nm",function() return newTxt(15, Color3.fromRGB(255,255,255)) end)
		nm.Text=pl.Name nm.Position=Vector2.new(top2.X, top2.Y-18) nm.Visible=true
		nameOff = 16
	else
		local n = pool[uid.."_nm"] if n then n.Visible=false end
	end

	-- dist above name
	if S.distESP then
		local dt = get(uid,"dt",function() return newTxt(13, Color3.fromRGB(160,200,255)) end)
		dt.Text=math.floor(dist).."m"
		dt.Position=Vector2.new(top2.X, top2.Y-18-nameOff) dt.Visible=true
	else
		local d = pool[uid.."_dt"] if d then d.Visible=false end
	end

	-- health bar left of box
	if S.healthESP then
		local pct = math.clamp(h.Health / math.max(h.MaxHealth,1), 0, 1)
		local barX = bx - 6

		local bg = get(uid,"hbg",function() return newRect(true, Color3.fromRGB(15,15,15), 0.85) end)
		bg.Position=Vector2.new(barX, by) bg.Size=Vector2.new(4, bh) bg.Visible=true

		local fg = get(uid,"hfg",function()
			local d=Drawing.new("Square") d.Filled=true d.Transparency=1 d.Visible=false return d
		end)
		local fh = bh * pct
		fg.Color=Color3.fromRGB(math.floor(255*(1-pct)), math.floor(220*pct), 30)
		fg.Position=Vector2.new(barX, by+(bh-fh))
		fg.Size=Vector2.new(4, math.max(fh,1)) fg.Visible=true
	else
		for _,k in ipairs({"hbg","hfg"}) do
			local d=pool[uid.."_"..k] if d then d.Visible=false end
		end
	end
end

local spinAngle = 0

RunService.RenderStepped:Connect(function(dt)
	fovCircle.Position=mid() fovCircle.Radius=S.fovR
	fovCircle.Visible=S.showFov and (S.aimbotOn or S.silentOn)

	if S.aimbotOn and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		local t = bestTarget()
		if t then
			local s2d   = toScreen(predicted(t.part))
			local delta = s2d - mid()
			local f     = math.clamp(1-S.smooth/100, 0.02, 1)
			mousemoverel(delta.X*f, delta.Y*f)
		end
	end

	if S.espOn then
		for _,pl in Players:GetPlayers() do
			if pl ~= lp then drawPlayer(pl) end
		end
	else
		hideAll()
	end

	if S.spinOn then
		spinAngle += S.spinSpd * dt
		local r = root()
		if r then r.CFrame=CFrame.new(r.CFrame.Position)*CFrame.Angles(0,math.rad(spinAngle),0) end
	end
end)

-- silent aim: hook click and redirect shot to best target
UIS.InputBegan:Connect(function(input, gp)
	if gp or input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	if not S.silentOn then return end
	if math.random(1,100) > S.hitChance then return end
	local t = bestTarget()
	if not t then return end
	local c = lp.Character
	if not c then return end
	pcall(function()
		local tool = c:FindFirstChildWhichIsA("Tool")
		if not tool then return end
		local remote = tool:FindFirstChild("Shoot") or tool:FindFirstChild("Fire")
			or tool:FindFirstChild("shoot") or tool:FindFirstChild("fire")
		if remote and remote:IsA("RemoteEvent") then
			remote:FireServer(t.part.Position, (t.part.Position - cam.CFrame.Position).Unit)
		end
	end)
end)

-- fly
local flyConn, bVel, bGyro

local function stopFly()
	if flyConn then flyConn:Disconnect() flyConn=nil end
	if bVel    then bVel:Destroy()       bVel=nil    end
	if bGyro   then bGyro:Destroy()      bGyro=nil   end
end

local function startFly()
	stopFly()
	local r = root()
	if not r then return end
	bVel=Instance.new("BodyVelocity",r)
	bVel.Velocity=Vector3.zero bVel.MaxForce=Vector3.new(1e5,1e5,1e5)
	bGyro=Instance.new("BodyGyro",r)
	bGyro.MaxTorque=Vector3.new(1e5,1e5,1e5) bGyro.P=1e4
	flyConn=RunService.RenderStepped:Connect(function()
		if not S.flyOn then stopFly() return end
		local r2=root() if not r2 then stopFly() return end
		local dir=Vector3.zero
		if UIS:IsKeyDown(Enum.KeyCode.W)         then dir+=cam.CFrame.LookVector  end
		if UIS:IsKeyDown(Enum.KeyCode.S)         then dir-=cam.CFrame.LookVector  end
		if UIS:IsKeyDown(Enum.KeyCode.A)         then dir-=cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D)         then dir+=cam.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.Space)     then dir+=Vector3.new(0,1,0)     end
		if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir-=Vector3.new(0,1,0)     end
		bVel.Velocity=dir.Magnitude>0 and dir.Unit*S.flySpd or Vector3.zero
		bGyro.CFrame=cam.CFrame
	end)
end

local noclipConn
local function setNoclip(v)
	if noclipConn then noclipConn:Disconnect() noclipConn=nil end
	if not v then
		local c=char()
		if c then for _,p in c:GetDescendants() do if p:IsA("BasePart") then p.CanCollide=true end end end
		return
	end
	noclipConn=RunService.Stepped:Connect(function()
		if not S.noclipOn then noclipConn:Disconnect() noclipConn=nil return end
		local c=char() if not c then return end
		for _,p in c:GetDescendants() do if p:IsA("BasePart") then p.CanCollide=false end end
	end)
end

local godConn
local function setGod(v)
	if godConn then godConn:Disconnect() godConn=nil end
	local h=hum()
	if not v then if h then h.MaxHealth=100 h.Health=100 end return end
	if h then h.MaxHealth=math.huge h.Health=math.huge end
	godConn=RunService.Heartbeat:Connect(function()
		if not S.godMode then godConn:Disconnect() godConn=nil return end
		local h2=hum() if h2 then h2.Health=h2.MaxHealth end
	end)
end

local freezeConn, frozenCF
local function setFreeze(v)
	if freezeConn then freezeConn:Disconnect() freezeConn=nil end
	local r=root()
	if not v then if r then r.Anchored=false end return end
	if r then
		frozenCF=r.CFrame r.Anchored=true
		freezeConn=RunService.Heartbeat:Connect(function()
			if not S.frozen then freezeConn:Disconnect() freezeConn=nil return end
			local r2=root() if r2 then r2.CFrame=frozenCF end
		end)
	end
end

local noFallConn, afkConn

UIS.JumpRequest:Connect(function()
	if not S.infJump then return end
	local h=hum() if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
end)

RunService.Heartbeat:Connect(function()
	local h=hum() if not h then return end
	if S.speedOn and h.WalkSpeed ~= S.ws then h.WalkSpeed=S.ws end
end)

lp.CharacterAdded:Connect(function(c)
	local h=c:WaitForChild("Humanoid")
	task.wait(0.15)
	if S.speedOn  then h.WalkSpeed=S.ws end
	h.JumpPower=S.jumpPow cam.FieldOfView=S.fovOvr
	if S.flyOn    then h.PlatformStand=true task.wait(0.2) startFly()  end
	if S.noclipOn then task.wait(0.2) setNoclip(true)                   end
	if S.godMode  then task.wait(0.2) setGod(true)                      end
	if S.frozen   then task.wait(0.2) setFreeze(true)                   end
end)

