	local h = hum()
	if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
end)

RunService.Heartbeat:Connect(function()
	local h = hum()
	if not h then return end
	if S.speedOn and h.WalkSpeed ~= S.ws then h.WalkSpeed=S.ws end
end)

local function applyToChar(c)
	local h = c:WaitForChild("Humanoid", 10)
	if not h then return end
	task.wait(0.15)
	if S.speedOn then h.WalkSpeed=S.ws end
	h.JumpPower     = S.jumpPow
	cam.FieldOfView = S.fovOvr
	if S.flyOn    then h.PlatformStand=true task.wait(0.2) startFly()  end
	if S.noclipOn then task.wait(0.2) setNoclip(true)                   end
	if S.godMode  then task.wait(0.2) setGod(true)                      end
	if S.frozen   then task.wait(0.2) setFreeze(true)                   end
end

lp.CharacterAdded:Connect(applyToChar)

local function hookPlayer(pl)
	pl.CharacterAdded:Connect(function()    removePlayer(tostring(pl.UserId)) end)
	pl.CharacterRemoving:Connect(function() removePlayer(tostring(pl.UserId)) end)
end

for _,pl in Players:GetPlayers() do
