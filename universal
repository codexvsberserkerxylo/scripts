local function vp2s(p)
	local v = cam:WorldToViewportPoint(p)
	return Vector2.new(v.X, v.Y), v.Z > 0
end
local function mid()
	return Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
end

