PlrTab:CreateSection("Teleport")
PlrTab:CreateButton({Name="Teleport to Cursor", Callback=function()
	local r = root()
	if not r then return end
	local ray    = cam:ScreenPointToRay(mouse.X, mouse.Y)
	local result = workspace:Raycast(ray.Origin, ray.Direction*1000)
	r.CFrame = result
		and CFrame.new(result.Position + Vector3.new(0,3,0))
		or  CFrame.new(cam.CFrame.Position + cam.CFrame.LookVector*20)
end})
PlrTab:CreateButton({Name="Teleport to Nearest Player", Callback=function()
	local r = root()
	if not r then return end
	local near, best = nil, math.huge
	for _,pl in Players:GetPlayers() do
		if pl ~= lp and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
			local d = (pl.Character.HumanoidRootPart.Position - r.Position).Magnitude
			if d < best then near=pl best=d end
		end
	end
	if near then
		r.CFrame = near.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3)
		Rayfield:Notify({Title="Teleport", Content="Jumped to "..near.Name, Duration=2})
	end
end})
PlrTab:CreateButton({Name="Rejoin", Callback=function()
	game:GetService("TeleportService"):Teleport(game.PlaceId, lp)
end})
PlrTab:CreateSection("Target Player")
local plrNames = {"(none)"}
for _,pl in Players:GetPlayers() do if pl ~= lp then table.insert(plrNames, pl.Name) end end
local tgtDrop = PlrTab:CreateDropdown({
	Name="Select Player", Options=plrNames, CurrentOption={"(none)"},
	MultipleOptions=false, Flag="TgtPlayer", Callback=function(_) end,
})
Players.PlayerAdded:Connect(function(pl)
	table.insert(plrNames, pl.Name)
	tgtDrop:Refresh(plrNames)
end)
Players.PlayerRemoving:Connect(function(pl)
	for i,n in ipairs(plrNames) do if n==pl.Name then table.remove(plrNames,i) break end end
	tgtDrop:Refresh(plrNames)
end)
PlrTab:CreateButton({Name="Teleport to Selected", Callback=function()
	local opt = tgtDrop.CurrentOption
	if not opt or opt[1]=="(none)" then return end
	local tgt = Players:FindFirstChild(opt[1])
	local r   = root()
	if tgt and tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart") and r then
		r.CFrame = tgt.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3)
	end
end})
