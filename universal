local function moveMouseBy(dx, dy)
	if S.aimMethod == "mousemoverel" then
		local ok = pcall(mousemoverel, dx, dy)
		if not ok then
			cam.CFrame = cam.CFrame * CFrame.Angles(-math.rad(dy*0.05), -math.rad(dx*0.05), 0)
		end
	elseif S.aimMethod == "camera" then
		cam.CFrame = cam.CFrame * CFrame.Angles(-math.rad(dy*0.05), -math.rad(dx*0.05), 0)
	end
end

local function hasLOS(pos)
	local r = root()
	if not r then return false end
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {lp.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	local result = workspace:Raycast(r.Position, pos - r.Position, params)
	if not result then return true end
	local model = result.Instance:FindFirstAncestorOfClass("Model")
	return model ~= nil and Players:GetPlayerFromCharacter(model) ~= nil
end

local function sameTeam(pl)
	if not lp.Team then return false end
	return pl.Team == lp.Team
end

local function targets()
	local out = {}
	local r = root()
	if not r then return out end
	for _,pl in Players:GetPlayers() do
		if pl == lp or sameTeam(pl) then continue end
		local c = pl.Character
		if not c then continue end
		local h = c:FindFirstChildOfClass("Humanoid")
		if not h or h.Health <= 0 then continue end
		local part = c:FindFirstChild(S.tPart) or c:FindFirstChild("HumanoidRootPart")
		if not part then continue end
		if not S.wallbang and not hasLOS(part.Position) then continue end
		local s, front = vp2s(part.Position)
		if not front then continue end
		if (s - mid()).Magnitude > S.fovR then continue end
		local d3 = (part.Position - r.Position).Magnitude
		if d3 > S.maxDist then continue end
		table.insert(out, {pl=pl, part=part, d2=(s-mid()).Magnitude, d3=d3, hp=h.Health})
	end
	return out
end

local function bestTarget()
	local list = targets()
	if #list == 0 then return nil end
	if S.priority == "Nearest" then
		table.sort(list, function(a,b) return a.d3 < b.d3 end)
	elseif S.priority == "Crosshair" then
		table.sort(list, function(a,b) return a.d2 < b.d2 end)
	elseif S.priority == "Lowest HP" then
		table.sort(list, function(a,b) return a.hp < b.hp end)
	elseif S.priority == "Random" then
		return list[math.random(1,#list)]
	end
	return list[1]
end

local SHOOT_NAMES = {
	"Shoot","shoot","Fire","fire","Fired","fired",
	"BulletHit","Hit","hit","DealDamage","Damage","damage",
	"OnShoot","ShootEvent","FireBullet","Attack","attack",
}
local function findRemote(tool)
	if not tool then return nil end
	for _,name in ipairs(SHOOT_NAMES) do
		local r = tool:FindFirstChild(name, true)
		if r and r:IsA("RemoteEvent") then return r end
	end
	for _,obj in tool:GetDescendants() do
		if obj:IsA("RemoteEvent") then return obj end
	end
	return nil
end

local pool = {}

local function get(uid, k, ctor)
	local key = uid.."_"..k
	if not pool[key] then pool[key] = ctor() end
	return pool[key]
end

local function hidePlayer(uid)
	local prefix = uid.."_"
	for k,d in pairs(pool) do
		if k:sub(1, #prefix) == prefix then d.Visible = false end
	end
end

local function removePlayer(uid)
	local prefix = uid.."_"
	local toRemove = {}
	for k,d in pairs(pool) do
		if k:sub(1, #prefix) == prefix then
			table.insert(toRemove, k)
			pcall(function() d:Remove() end)
		end
	end
	for _,k in ipairs(toRemove) do pool[k] = nil end
end

local function hideAll()
	for _,d in pairs(pool) do d.Visible = false end
end

local function newBox(filled, col, alpha, thick)
	local d = Drawing.new("Square")
	d.Visible      = false
	d.Thickness    = thick or 1
	d.Filled       = filled or false
	d.Color        = col or ACCENT
	d.Transparency = alpha or 1
	return d
end

local function newLine(col, thick)
	local d = Drawing.new("Line")
	d.Visible      = false
	d.Thickness    = thick or 1
	d.Color        = col or ACCENT
	d.Transparency = 1
	return d
end

local function newText(sz, col)
	local d = Drawing.new("Text")
	d.Visible      = false
	d.Size         = sz or 13
	d.Color        = col or Color3.fromRGB(255,255,255)
	d.Outline      = true
	d.Center       = true
	d.Font         = 2
	d.Transparency = 1
	return d
end

