        seen[name]=true
        mkEntry(isEv and eventList or normalList,name,isEv,function()
            local h=hrp(); if h then h.CFrame=cf2+Vector3.new(0,8,0); notify("tp",name) end
        end)
    end
    local zones=workspace:FindFirstChild("zones")
    if zones then
        local pz=zones:FindFirstChild("player"); local fz2=zones:FindFirstChild("fishing")
        if pz then for _,z in pz:GetChildren() do addLoc(z.Name,getCF(z),false) end end
        if fz2 then for _,z in fz2:GetChildren() do addLoc(z.Name,getCF(z),true) end end
    end
    local world=workspace:FindFirstChild("world"); local evF=world and world:FindFirstChild("events")
    if evF then for _,e in evF:GetChildren() do addLoc(e.Name,getCF(e),true) end end
end
