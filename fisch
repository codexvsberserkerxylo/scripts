local function reg(inst,key,prop)
    table.insert(colorRegs,{inst=inst,key=key,prop=prop or "BackgroundColor3"})
    return inst
end
local function applyTheme(name)
    local th=THEMES[name]; if not th then return end
    for k,v in th do T[k]=v end
    for _,r in colorRegs do
        if r.inst and r.inst.Parent and T[r.key] then
            TS:Create(r.inst,TweenInfo.new(0.3,Enum.EasingStyle.Quart),{[r.prop]=T[r.key]}):Play()
