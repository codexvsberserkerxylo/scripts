    trackBG.BackgroundColor3=T.dim; trackBG.Text=""; trackBG.BorderSizePixel=0; cr(trackBG,2); reg(trackBG,"dim")
    local fill=Instance.new("Frame",trackBG); fill.Size=UDim2.new((def-mn)/(mx-mn),0,1,0); fill.BackgroundColor3=ac; fill.BorderSizePixel=0; cr(fill,2)
    local thumb=Instance.new("Frame",trackBG); thumb.Size=UDim2.new(0,11,0,11); thumb.AnchorPoint=Vector2.new(.5,.5)
    thumb.Position=UDim2.new((def-mn)/(mx-mn),0,.5,0); thumb.BackgroundColor3=T.atxt; thumb.BorderSizePixel=0; cr(thumb,6); reg(thumb,"atxt")
    local drag=false
    local function upd()
        local pct=math.clamp((UIS:GetMouseLocation().X-trackBG.AbsolutePosition.X)/trackBG.AbsoluteSize.X,0,1)
        fill.Size=UDim2.new(pct,0,1,0); thumb.Position=UDim2.new(pct,0,.5,0)
        local v=math.floor(mn+pct*(mx-mn)); vl2.Text=tostring(v); cb(v)
    end
