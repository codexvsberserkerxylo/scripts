-- original crater system from the script (no relic filtering)
local function findStarCraters()
    local found={}
    local function scanParent(p)
        for _,v in p:GetChildren() do
            local n=v.Name:lower()
            if n:find("star crater",1,true) or n:find("starcrater",1,true) then table.insert(found,v) end
            if v:IsA("Model") or v:IsA("Folder") then scanParent(v) end
        end
    end
    local world=workspace:FindFirstChild("world")
    local ints=world and world:FindFirstChild("interactables")
    if ints then scanParent(ints) end
    scanParent(workspace)
    return found
end

local function fireCrater(model)
    local h=hrp(); if not h or not model or not model.Parent then return end
    local cf=getCF(model); if not cf then return end
    h.CFrame=cf*CFrame.new(0,2,2); task.wait(0.15)
    -- find prompt
    local prompt=nil
    for _,d in model:GetDescendants() do if d:IsA("ProximityPrompt") then prompt=d; break end end
    -- fire multiple times to make sure it registers
    if prompt and fireproximityprompt then
        for _=1,3 do
            pcall(fireproximityprompt,prompt)
            task.wait(0.15)
        end
        return
    end
    -- fallback: spam E key
    local t0=tick()
    while (tick()-t0)<1.2 and model.Parent do
        VIM:SendKeyEvent(true,Enum.KeyCode.E,false,game); task.wait(0.05)
        VIM:SendKeyEvent(false,Enum.KeyCode.E,false,game); task.wait(0.05)
    end
end

local function doServerHop()
    pcall(function()
        saveHopFlag(true)
        saveCfg(); saveSlots(); saveFarmCount()
        local qot=queue_on_teleport or queueonteleport
            or (syn and (syn.queue_on_teleport or syn.queueonteleport))
            or (fluxus and fluxus.queue_on_teleport)
            or (getgenv and getgenv().queue_on_teleport)
        if qot then
            pcall(qot,'loadstring(game:HttpGet("https://raw.githubusercontent.com/nick2132131/rscripts/refs/heads/main/fisch"))()')
            task.wait(0.5); dbg("QOT queued")
        else dbg("QOT not available") end
        local function getPage(cursor)
            local url="https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
            if cursor then url=url.."&cursor="..cursor end
            local ok,raw=pcall(game.HttpGet,game,url)
            return ok and HTTP:JSONDecode(raw) or nil
        end
        local cursor=nil; local servers={}
        for _=1,5 do
            local data=getPage(cursor); if not data or not data.data then break end
            for _,s in pairs(data.data) do
                if s.id~=game.JobId and (s.playing or 0)<17 then table.insert(servers,s.id) end
            end
            cursor=data.nextPageCursor; if not cursor then break end
            task.wait(0.05)
        end
        if #servers>0 then
            local id=servers[math.random(1,#servers)]
            dbg("hop -> "..id:sub(1,8))
            TeleServ:TeleportToPlaceInstance(game.PlaceId,id,lp)
        else
            dbg("hop: fallback rejoin"); saveHopFlag(false)
            TeleServ:Teleport(game.PlaceId,lp)
        end
    end)
end

local starFarmRunning=false
local starStatusLbl=nil; local starStatusDot=nil

task.spawn(function()
    task.wait(cfg.StartDelay)
    local arrivedFromHop,farmWasOn=popHopFlag()
    if arrivedFromHop then
        starCraterServerCount=starCraterServerCount+1; saveFarmCount()
        sendWebhook("autofarm"); dbg("arrived — total: "..starCraterServerCount)
        if starStatusLbl then starStatusLbl.Text="server #"..starCraterServerCount.." — ready" end
        if farmWasOn then cfg.AutoStarCrater=true end
    end
    while _G.__lx and task.wait(0.3) do
        if not cfg.AutoStarCrater then
            if starFarmRunning then
                starFarmRunning=false
                if starStatusLbl then starStatusLbl.Text="idle" end
                if starStatusDot then TS:Create(starStatusDot,TweenInfo.new(0.3),{BackgroundColor3=T.dim}):Play() end
            end
            continue
        end
        if starFarmRunning then continue end
        starFarmRunning=true
        if starStatusLbl then starStatusLbl.Text="scanning..." end
        local craters=findStarCraters()
        dbg("craters: "..#craters)
        if #craters==0 then
            if starStatusLbl then starStatusLbl.Text="no craters — hopping..." end
            if starStatusDot then TS:Create(starStatusDot,TweenInfo.new(0.3),{BackgroundColor3=T.yell}):Play() end
            task.wait(0.1)
            if cfg.AutoStarCrater and cfg.StarCraterServerHop then doServerHop(); task.wait(20) end
            starFarmRunning=false; continue
        end
        for i,crater in craters do
            if not cfg.AutoStarCrater or not _G.__lx or not crater.Parent then break end
            if starStatusLbl then starStatusLbl.Text="crater "..i.."/"..#craters end
            if starStatusDot then TS:Create(starStatusDot,TweenInfo.new(0.3),{BackgroundColor3=T.green}):Play() end
            fireCrater(crater)
            -- also click bottom-center of screen in case the game shows a button there
            task.spawn(function()
                local vp=workspace.CurrentCamera.ViewportSize
                local cx=vp.X/2; local cy=vp.Y*0.85
                for _=1,3 do
                    VIM:SendMouseButtonEvent(cx,cy,0,true,game,1); task.wait(0.05)
                    VIM:SendMouseButtonEvent(cx,cy,0,false,game,1); task.wait(0.05)
                end
            end)
            task.wait(cfg.FarmDelay*cfg.FarmSpeed)
        end
        if not cfg.AutoStarCrater or not _G.__lx then starFarmRunning=false; continue end
        if starStatusLbl then starStatusLbl.Text="done — hopping..." end
        if cfg.StarCraterServerHop then
            doServerHop(); task.wait(20); saveHopFlag(false)
        else
            starCraterServerCount=starCraterServerCount+1; saveFarmCount(); sendWebhook("autofarm")
        end
        starFarmRunning=false
    end
end)

