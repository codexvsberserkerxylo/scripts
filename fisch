    ll.Text=label; ll.Font=Enum.Font.GothamMedium; ll.TextSize=12; ll.TextColor3=T.txt; ll.TextXAlignment=Enum.TextXAlignment.Left; reg(ll,"txt","TextColor3")
    local vl2=Instance.new("TextLabel",hf); vl2.Size=UDim2.new(0,46,1,0); vl2.Position=UDim2.new(1,-46,0,0)
    vl2.BackgroundTransparency=1; vl2.Text=tostring(def); vl2.Font=Enum.Font.GothamBold; vl2.TextSize=12; vl2.TextColor3=ac; vl2.TextXAlignment=Enum.TextXAlignment.Right
    local trackBG=Instance.new("TextButton",f)
