local function setBoatFly(v)
    if boatFlyConn then boatFlyConn:Disconnect(); boatFlyConn=nil end; if not v then return end
    boatFlyConn=RunService.Heartbeat:Connect(function(dt)
        if not cfg.BoatFly then return end
        local boat=getBoat(); local root=getBoatRoot(boat); if not root then return end
        if chatOpen() then root.AssemblyLinearVelocity=Vector3.zero; root.AssemblyAngularVelocity=Vector3.zero; return end
        local cam=workspace.CurrentCamera; local cf=root.CFrame; local mv=Vector3.zero
        local look=cam.CFrame.LookVector; local right=cam.CFrame.RightVector
        if UIS:IsKeyDown(Enum.KeyCode.W) then mv=mv+look  end
        if UIS:IsKeyDown(Enum.KeyCode.S) then mv=mv-look  end
        if UIS:IsKeyDown(Enum.KeyCode.A) then mv=mv-right end
        if UIS:IsKeyDown(Enum.KeyCode.D) then mv=mv+right end
        if UIS:IsKeyDown(Enum.KeyCode.E) then mv=mv+Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.Q) then mv=mv-Vector3.new(0,1,0) end
        if mv.Magnitude>0 then root.CFrame=CFrame.new(cf.Position+mv.Unit*cfg.BoatFlySpeed*dt)*(cf-cf.Position) end
        root.AssemblyLinearVelocity=Vector3.zero; root.AssemblyAngularVelocity=Vector3.zero
        for _,p in boat:GetDescendants() do if p:IsA("BasePart") and p~=root then p.AssemblyLinearVelocity=Vector3.zero; p.AssemblyAngularVelocity=Vector3.zero end end
    end)
end
