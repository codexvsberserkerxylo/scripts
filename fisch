local function saveCfg()
    pcall(function()
        if not writefile then return end
        local t={}; for k,v in cfg do if type(v)~="nil" then t[k]=v end end
        writefile(CFG_FILE,HTTP:JSONEncode(t))
    end)
    pcall(function()
        if not writefile then return end
        writefile(EVENTS_FILE,HTTP:JSONEncode(eventEnabled))
    end)
end
local function loadCfg()
    pcall(function()
        if not readfile then return end
        local ok,raw=pcall(readfile,CFG_FILE); if not ok then return end
        local d=HTTP:JSONDecode(raw)
        for k,v in d do if cfg[k]~=nil then cfg[k]=v end end
    end)
    pcall(function()
        if not readfile then return end
        local ok,raw=pcall(readfile,EVENTS_FILE); if not ok then return end
        local d=HTTP:JSONDecode(raw)
        for k,v in d do if eventEnabled[k]~=nil then eventEnabled[k]=v end end
    end)
end

local function saveSlots()
    pcall(function()
        if not writefile then return end
        local t={count=slotCount}
        for i=1,slotCount do
            if slots[i] then
                local c=slots[i]
                local _,_,_,r00,r01,r02,r10,r11,r12,r20,r21,r22=c:GetComponents()
                t[tostring(i)]={x=c.X,y=c.Y,z=c.Z,r00=r00,r01=r01,r02=r02,r10=r10,r11=r11,r12=r12,r20=r20,r21=r21,r22=r22,name=slotNames[i]}
            elseif slotNames[i] then t[tostring(i)]={name=slotNames[i]} end
        end
        writefile(SLOTS_FILE,HTTP:JSONEncode(t))
    end)
end
local function loadSlots()
    pcall(function()
        if not readfile then return end
        local ok,raw=pcall(readfile,SLOTS_FILE); if not ok then return end
        local d=HTTP:JSONDecode(raw)
        if d.count then slotCount=math.max(5,d.count) end
        for i=1,slotCount do
            local s=d[tostring(i)]
            if s then
                if s.x then
                    slots[i]=s.r00 and CFrame.new(s.x,s.y,s.z,s.r00,s.r01,s.r02,s.r10,s.r11,s.r12,s.r20,s.r21,s.r22) or CFrame.new(s.x,s.y,s.z)
                end
                slotNames[i]=s.name
            end
        end
    end)
end

