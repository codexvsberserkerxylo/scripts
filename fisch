            if activeEvent then cfg.Frozen=false; if freezeConn then freezeConn:Disconnect(); freezeConn=nil end; activeEvent=nil; lastEventPos=nil end
            continue
        end

        -- if there's a cancelled event still in the world, wait for it to despawn
        if cancelledEvent then
            local cancelEv=nil
            for _,ev in EVENTS do if ev.name==cancelledEvent then cancelEv=ev; break end end
            if cancelEv then
                local cf=getEventCF(cancelEv)
                if not cf then
                    -- gone, allow it to be tracked again next time
                    dbg("event: cancelled event despawned, re-enabling "..cancelledEvent)
                    cancelledEvent=nil
                end
            else
                cancelledEvent=nil
            end
            continue
        end

        if activeEvent then
            local cf=getEventCF(activeEvent)
            if cf then
                local np=cf.Position; local first=not lastEventPos
                local moved=not first and (np-lastEventPos).Magnitude>1.5
                if first or moved then
                    local yOff
                    if HIGH_Y[activeEvent.name] then yOff=100
                    elseif LOW_Y[activeEvent.name] then yOff=20
                    else yOff=40 end
                    local zOff=FORWARD_Z[activeEvent.name] and 60 or 0
                    local dest=CFrame.new(np.X,np.Y+yOff,np.Z+zOff)
                    local h=hrp()
                    if h then h.CFrame=dest; frozenCF=dest; if not cfg.Frozen then cfg.Frozen=true; setFrozen(true) end end
                    lastEventPos=np
                end
            else
                -- event gone: TP to return slot 5 times then freeze
                cfg.Frozen=false
                if freezeConn then freezeConn:Disconnect(); freezeConn=nil end
                notify("event",activeEvent.name.." gone"); dbg("event: "..activeEvent.name.." gone")
                if cfg.EventReturnSlot and slots[cfg.EventReturnSlot] then
                    local h=hrp()
                    if h then
                        for _=1,5 do
                            h.CFrame=slots[cfg.EventReturnSlot]
                            task.wait(0.06)
                        end
                        -- freeze at return slot
                        frozenCF=slots[cfg.EventReturnSlot]
                        cfg.Frozen=true; setFrozen(true)
                        dbg("event: froze at return slot "..cfg.EventReturnSlot)
                    end
                end
                activeEvent=nil; lastEventPos=nil
            end
            continue
        end

        for _,ev in EVENTS do
            if not eventEnabled[ev.name] then continue end
            local cf=getEventCF(ev)
            if cf then
                activeEvent=ev; lastEventPos=nil
                notify("event",ev.name); sendWebhook("event",ev.name); dbg("event: "..ev.name); break
            end
        end
    end
end)

