local noclipConn,origCollide=nil,{}
local function setNoClip(v)
    if noclipConn then noclipConn:Disconnect(); noclipConn=nil end
    if not v then
        for p,w in origCollide do if p and p.Parent then p.CanCollide=w end end
        origCollide={}; return
    end
    origCollide={}
    if lp.Character then
        for _,p in lp.Character:GetDescendants() do
            if p:IsA("BasePart") and not p.Anchored then origCollide[p]=p.CanCollide end
        end
    end
    noclipConn=RunService.Stepped:Connect(function()
        if not lp.Character or swimming() then return end
        for _,p in lp.Character:GetDescendants() do
            if p:IsA("BasePart") and not p.Anchored then p.CanCollide=false end
        end
    end)
end

