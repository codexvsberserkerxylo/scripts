local function getEventCF(ev)
    local zn=ev.hunt and (ev.zone.." Hunt") or ev.zone
    local fz=workspace:FindFirstChild("zones") and workspace.zones:FindFirstChild("fishing")
    if fz then
        local z=fz:FindFirstChild(zn) or fz:FindFirstChild(ev.zone)
        if z then
            if z:IsA("BasePart") then return z.CFrame end
            if z:IsA("Model") then return z:GetPivot() end
            local p=z:FindFirstChildWhichIsA("BasePart"); if p then return p.CFrame end
        end
    end
    local function scan(parent,depth)
        if depth>6 then return nil end
        for _,o in parent:GetChildren() do
            local n=o.Name
            if n==zn or n==ev.zone or n==ev.zone.." Hunt" then
                if o:IsA("BasePart") then return o.CFrame end
                if o:IsA("Model") then return o:GetPivot() end
                local p=o:FindFirstChildWhichIsA("BasePart"); if p then return p.CFrame end
            end
            local r=scan(o,depth+1); if r then return r end
        end
    end
    return scan(workspace,0)
end

