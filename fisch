    for _,ch in normalList:GetChildren() do if ch:IsA("TextButton") then ch:Destroy() end end
    for _,ch in eventList:GetChildren()  do if ch:IsA("TextButton") then ch:Destroy() end end
    local q=searchTB.Text:lower(); local seen={}
